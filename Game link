<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Game Hub</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #0f0f0f;
  color: white;
  display: flex;
}

/* Sidebar */
.sidebar {
  width: 220px;
  background: #111;
  height: 100vh;
  padding: 20px;
  box-sizing: border-box;
}

.sidebar h2 {
  margin-bottom: 20px;
}

.sidebar input {
  width: 100%;
  padding: 8px;
  margin-bottom: 15px;
  background: #222;
  border: none;
  color: white;
}

/* Main */
.main {
  flex: 1;
  padding: 20px;
  overflow-y: auto;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 15px;
}

.card {
  background: #1a1a1a;
  border-radius: 10px;
  padding: 10px;
  cursor: pointer;
  transition: 0.2s;
  text-align: center;
}

.card:hover {
  transform: scale(1.05);
  background: #2a2a2a;
}

.card img {
  width: 100%;
  height: 90px;
  object-fit: cover;
  border-radius: 8px;
}

/* Player */
.player {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: black;
  display: none;
  flex-direction: column;
}

.player iframe {
  flex: 1;
  border: none;
}

.close {
  padding: 10px;
  background: red;
  text-align: center;
  cursor: pointer;
}
</style>
</head>

<body>

<div class="sidebar">
  <h2>🎮 Game Hub</h2>
  <input type="text" id="search" placeholder="Search..." oninput="searchGames()">
</div>

<div class="main">
  <div class="grid" id="gameGrid"></div>
</div>

<div class="player" id="player">
  <div class="close" onclick="closeGame()">Close</div>
  <iframe id="frame"></iframe>
</div>

<script>
const games = [
  {
    name: "2048",
    url: "https://play2048.co/",
    img: "https://upload.wikimedia.org/wikipedia/commons/1/18/2048_logo.svg"
  },
  {
    name: "Slither.io",
    url: "https://slither.io/",
    img: "https://slither.io/s/favicon.png"
  },
  {
    name: "Agar.io",
    url: "https://agar.io/",
    img: "https://upload.wikimedia.org/wikipedia/en/3/3d/Agar.io_logo.png"
  },
  {
    name: "Snake",
    url: "https://playsnake.org/",
    img: "https://playsnake.org/favicon.ico"
  },
  {
    name: "Cookie Clicker",
    url: "https://orteil.dashnet.org/cookieclicker/",
    img: "https://orteil.dashnet.org/favicon.ico"
  }
];

function render(list) {
  const grid = document.getElementById("gameGrid");
  grid.innerHTML = "";

  list.forEach(game => {
    const div = document.createElement("div");
    div.className = "card";
    div.innerHTML = `
      <img src="${game.img}">
      <p>${game.name}</p>
    `;
    div.onclick = () => openGame(game.url);
    grid.appendChild(div);
  });
}

function openGame(url) {
  // Try iframe first
  document.getElementById("player").style.display = "flex";
  document.getElementById("frame").src = url;
}

function closeGame() {
  document.getElementById("player").style.display = "none";
  document.getElementById("frame").src = "";
}

function searchGames() {
  const term = document.getElementById("search").value.toLowerCase();
  const filtered = games.filter(g => g.name.toLowerCase().includes(term));
  render(filtered);
}

// Fallback if iframe blocked
document.getElementById("frame").onerror = () => {
  window.open(document.getElementById("frame").src, "_blank");
};

render(games);
</script>

</body>
